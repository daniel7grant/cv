---
import Slide from './Slide.astro';

interface Props {
    email: string;
    github: string;
}

const { email, github } = Astro.props;
---

<Slide class="contact">
    <h2>Contacts</h2>
    <div class="contact-email">
        <h3>Send me a mail</h3>
        <input
            name="email"
            type="text"
            class="contact-input"
            id="contact-input-email"
            value={email}
            readonly
        />
        <div class="contact-buttons">
            <a class="mailto" href={`mailto:${email}`} target="_blank" rel="noopener"
                >Send an email</a
            >
            <a class="copy" href="#" data-clipboard-target="#contact-input-email">
                Copy to clipboard
            </a>
        </div>
    </div>
    <div class="contact-github">
        <h3>Look at my GitHub repos</h3>
        <input
            name="github"
            type="text"
            class="contact-input"
            id="contact-input-github"
            value={github}
            readonly
        />
        <div class="contact-buttons">
            <a class="github-url" href={github} target="_blank" rel="noopener">Open Github</a>
        </div>
    </div>
</Slide>

<script>
    import Clipboard from 'clipboard';
    new Clipboard('a.copy');

    (Array.from(document.querySelectorAll('input.contact-input')) as HTMLInputElement[]).forEach(
        (element) =>
            element.addEventListener('click', (ev) => {
                element.focus();
                element.select();
            }),
    );
</script>

<style lang="scss">
    @use '../style/variables.scss' as *;
    @use '../style/mixins.scss' as *;

    .contact {
        padding: 0.75 * $h1-size 0 0 0;
        margin: auto;
        text-align: center;
        width: $lang-width;
        max-width: 100%;

        @include if-tablet-laptop {
            padding: 0.5 * $h1-size 0.5 * $h1-size 0 0.5 * $h1-size;
        }
        @include if-mobile {
            padding: 0.75 * $h1-size 0.25 * $h1-size 0 0.25 * $h1-size;
        }

        h2 {
            margin-top: 0;
        }
        & > div {
            margin-bottom: $spacing-big;
        }
        input {
            width: 100%;
            text-align: center;
            border-radius: $spacing;
            padding: $spacing;
            font-size: 0.2 * $h1-size;
        }
        div.contact-buttons {
            display: flex;
            a {
                flex: 1 0 auto;
                padding: $spacing;
                margin: $spacing 0;
                background-color: $acolor;
                color: $bgcolor;
                text-decoration: none;
                &:hover {
                    background-color: $selectcolor;
                }
            }
        }
    }
</style>
