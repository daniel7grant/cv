---
import Slide from './Slide.astro';

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<Slide class="cover">
    <picture>
        <source srcset="/olti.webp" type="image/webp" />
        <source srcset="/olti.png" type="image/png" />
        <img src="/olti.png" alt="Me in a suit" />
    </picture>
    <h1>{title}</h1>
</Slide>

<style lang="scss">
    @use '../style/variables.scss' as *;
    @use '../style/mixins.scss' as *;

    img:not(.arrow) {
        height: 100vh;
        width: auto;
    }
    h1 {
        box-sizing: border-box;
        position: absolute;
        width: 100%;
        top: 50vh;
        @include if-desktop {
            padding-left: $h1-padding;
        }
    }
</style>
